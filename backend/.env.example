# Environment Configuration for Lit Review Assistant
# Copy values here to .env file in production

# ============================================================
# HUGGINGFACE HUB CONFIGURATION
# ============================================================

# HuggingFace API token for faster model downloads
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your-hf-token-here

# Disable symlinks warning on Windows (performance)
HF_HUB_DISABLE_SYMLINKS=1

# ============================================================
# CRITICAL: JWT AUTHENTICATION (SECURITY)
# ============================================================

# REQUIRED: Generate a strong JWT secret key with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-here-change-in-production

JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================
# ENVIRONMENT & SECURITY SETTINGS
# ============================================================

# Set to 'production' when deploying to production
ENVIRONMENT=development

# Must be 'true' in production (requires HTTPS)
COOKIE_SECURE=false

# Use 'strict' in production, 'lax' in development
COOKIE_SAMESITE=lax

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# SQLite for development (default):
DATABASE_URL=sqlite:///./litreview.db

# PostgreSQL for production (recommended):
# DATABASE_URL=postgresql://user:password@localhost:5432/litreview

# Database connection pooling (for PostgreSQL)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true

# ============================================================
# FILE UPLOAD SECURITY LIMITS
# ============================================================

# Max size per file in bytes (default: 100MB = 104857600)
MAX_FILE_SIZE_BYTES=104857600

# Max total upload per request in bytes (default: 500MB = 524288000)
MAX_TOTAL_UPLOAD_SIZE_BYTES=524288000

# ============================================================
# FRONTEND CORS CONFIGURATION
# ============================================================

# Comma-separated frontend origins (CRITICAL for security)
# For production, whitelist your actual domain
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production example:
# FRONTEND_ORIGINS=https://myapp.com,https://www.myapp.com

# ============================================================
# HUGGINGFACE MODEL CACHE (Performance Optimization)
# ============================================================

# Directory for caching downloaded models (persists across restarts)
# Default: data/models (relative path)
# For production: /opt/litreview/models or similar persistent path
HF_HOME=data/models

# HuggingFace API token for faster downloads and higher rate limits
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your-hf-token-here

# Disable symlinks warning on Windows (Windows doesn't support symlinks well)
HF_HUB_DISABLE_SYMLINKS=1

# ============================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================
#
# Before deploying to production:
#
# 1. Generate secure JWT_SECRET_KEY:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 2. Set environment variables:
#    ENVIRONMENT=production
#    JWT_SECRET_KEY=<your-generated-key>
#    COOKIE_SECURE=true
#    COOKIE_SAMESITE=strict
#    FRONTEND_ORIGINS=<your-domain>
#
# 3. Migrate database to PostgreSQL:
#    DATABASE_URL=postgresql://...
#
# 4. Configure HTTPS (nginx reverse proxy recommended)
#
# 5. Enable secure headers:
#    - Strict-Transport-Security
#    - X-Content-Type-Options
#    - X-Frame-Options
#    - Content-Security-Policy
